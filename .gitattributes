# Normalize line endings. Critical for shell scripts: CRLF breaks the shebang on Linux
# ("bad interpreter"), and these scripts run on the Raspberry Pi.
* text=auto eol=lf

*.sh   text eol=lf
*.py   text eol=lf
*.js   text eol=lf
*.svelte text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.toml text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.service text eol=lf

# Binary assets (none yet, but keep git from touching them later)
*.png binary
*.jpg binary
*.ico binary
