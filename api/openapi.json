  "components": {
    "schemas": {
      "CreateTimerBody": {
        "properties": {
          "duration_ms": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Duration Ms"
          },
          "label": {
            "type": "string",
            "title": "Label",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "duration_ms"
        ],
        "title": "CreateTimerBody"
      },
      "GroupRole": {
        "type": "string",
        "enum": [
          "solo",
          "leader",
          "member"
        ],
        "title": "GroupRole"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PlayBody": {
        "properties": {
          "device_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Device Id"
          },
          "context_uri": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Context Uri"
          },
          "uris": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Uris"
          },
          "offset": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Offset"
          }
        },
        "type": "object",
        "title": "PlayBody",
        "description": "Start playback. Either a context (playlist/album/artist uri) or explicit track uris;\ndevice_id picks the target (omitted = the user's current/active device)."
      },
      "PlaybackState": {
        "type": "string",
        "enum": [
          "playing",
          "paused",
          "stopped",
          "buffering"
        ],
        "title": "PlaybackState"
      },
      "PlayerState": {
        "properties": {
          "state": {
            "$ref": "#/components/schemas/PlaybackState",
            "default": "stopped"
          },
          "track": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Track"
              },
              {
                "type": "null"
              }
            ]
          },
          "position_ms": {
            "type": "integer",
            "title": "Position Ms",
            "default": 0
          },
          "volume": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Volume",
            "default": 50
          },
          "shuffle": {
            "type": "boolean",
            "title": "Shuffle",
            "default": false
          },
          "repeat": {
            "$ref": "#/components/schemas/RepeatMode",
            "default": "off"
          }
        },
        "type": "object",
        "title": "PlayerState",
        "description": "Everything the now-playing screen needs."
      },
      "RepeatMode": {
        "type": "string",
        "enum": [
          "off",
          "track",
          "context"
        ],
        "title": "RepeatMode"
      },
      "SeekBody": {
        "properties": {
          "position_ms": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Position Ms"
          }
        },
        "type": "object",
        "required": [
          "position_ms"
        ],
        "title": "SeekBody"
      },
      "Snapshot": {
        "properties": {
          "unit": {
            "$ref": "#/components/schemas/UnitInfo"
          },
          "player": {
            "$ref": "#/components/schemas/PlayerState"
          },
          "timers": {
            "items": {
              "$ref": "#/components/schemas/TimerInfo"
            },
            "type": "array",
            "title": "Timers"
          },
          "voice": {
            "$ref": "#/components/schemas/VoiceState"
          },
          "version": {
            "type": "string",
            "title": "Version"
          }
        },
        "type": "object",
        "required": [
          "unit",
          "player",
          "version"
        ],
        "title": "Snapshot",
        "description": "Full state returned by GET /api/state and pushed on WS connect."
      },
      "TimerInfo": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "label": {
            "type": "string",
            "title": "Label",
            "default": ""
          },
          "duration_ms": {
            "type": "integer",
            "title": "Duration Ms"
          },
          "fires_at_ms": {
            "type": "integer",
            "title": "Fires At Ms"
          },
          "state": {
            "$ref": "#/components/schemas/TimerState",
            "default": "running"
          }
        },
        "type": "object",
        "required": [
          "id",
          "duration_ms",
          "fires_at_ms"
        ],
        "title": "TimerInfo",
        "description": "A countdown timer or alarm. `fires_at_ms` is a Unix epoch so the UI can count\ndown locally between server ticks (like player position), no polling needed."
      },
      "TimerState": {
        "type": "string",
        "enum": [
          "running",
          "fired"
        ],
        "title": "TimerState"
      },
      "Track": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "artist": {
            "type": "string",
            "title": "Artist"
          },
          "album": {
            "type": "string",
            "title": "Album",
            "default": ""
          },
          "artwork_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Artwork Url"
          },
          "duration_ms": {
            "type": "integer",
            "title": "Duration Ms",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "id",
          "title",
          "artist"
        ],
        "title": "Track"
      },
      "TransferBody": {
        "properties": {
          "device_id": {
            "type": "string",
            "title": "Device Id"
          },
          "play": {
            "type": "boolean",
            "title": "Play",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "device_id"
        ],
        "title": "TransferBody"
      },
      "UnitInfo": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "room": {
            "type": "string",
            "title": "Room"
          },
          "group_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Group Id"
          },
          "role": {
